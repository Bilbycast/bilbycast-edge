{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8081
  },
  "flows": [
    {
      "id": "rtp-to-srt",
      "name": "RTP to SRT Bridge",
      "enabled": true,
      "input": {
        "type": "srt",
        "mode": "caller",
        "local_addr": "0.0.0.0:9001",
        "remote_addr": "127.0.0.1:9000",
        "latency_ms": 200
      },
      "outputs": [
        {
          "type": "rtp",
          "id": "rtp-in",
          "name": "RTP Input",
          "dest_addr": "127.0.0.1:5005"
        }
      ]
    }
  ]
}
