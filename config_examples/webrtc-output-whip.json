{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8080
  },
  "monitor": {
    "listen_addr": "0.0.0.0",
    "listen_port": 9090
  },
  "flows": [
    {
      "id": "srt-to-webrtc",
      "name": "SRT Input to WebRTC (WHIP)",
      "enabled": true,
      "input": {
        "type": "srt",
        "mode": "listener",
        "local_addr": "0.0.0.0:9000",
        "latency_ms": 120
      },
      "outputs": [
        {
          "type": "webrtc",
          "id": "whip-out",
          "name": "WebRTC WHIP Output",
          "whip_url": "https://whip.example.com/ingest/stream1",
          "bearer_token": "YOUR_BEARER_TOKEN",
          "video_only": true
        }
      ]
    }
  ]
}
