{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8080
  },
  "monitor": {
    "listen_addr": "0.0.0.0",
    "listen_port": 9090
  },
  "flows": [
    {
      "id": "flow-rtp-to-srt",
      "name": "RTP In -> SRT Caller (to C++ listener)",
      "enabled": true,
      "input": {
        "type": "rtp",
        "bind_addr": "0.0.0.0:5000"
      },
      "outputs": [
        {
          "type": "srt",
          "id": "srt-caller-out",
          "name": "SRT to C++ Listener",
          "mode": "caller",
          "local_addr": "0.0.0.0:0",
          "remote_addr": "127.0.0.1:9000",
          "latency_ms": 200
        }
      ]
    },
    {
      "id": "flow-srt-to-rtp",
      "name": "SRT Listener (from C++ caller) -> RTP Out",
      "enabled": true,
      "input": {
        "type": "srt",
        "mode": "listener",
        "local_addr": "0.0.0.0:9001",
        "latency_ms": 200
      },
      "outputs": [
        {
          "type": "rtp",
          "id": "rtp-out",
          "name": "RTP Output",
          "dest_addr": "127.0.0.1:5005"
        }
      ]
    }
  ]
}
