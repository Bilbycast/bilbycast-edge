{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8080
  },
  "monitor": {
    "listen_addr": "0.0.0.0",
    "listen_port": 9090
  },
  "flows": [
    {
      "id": "flow-fan-out",
      "name": "SRT In -> 2x SRT + 1x RTP (Fan-Out)",
      "enabled": true,
      "input": {
        "type": "srt",
        "mode": "listener",
        "local_addr": "0.0.0.0:9001",
        "latency_ms": 200
      },
      "outputs": [
        {
          "type": "srt",
          "id": "srt-out-1",
          "name": "SRT to Listener A",
          "mode": "caller",
          "local_addr": "0.0.0.0:0",
          "remote_addr": "127.0.0.1:9100",
          "latency_ms": 200
        },
        {
          "type": "srt",
          "id": "srt-out-2",
          "name": "SRT to Listener B",
          "mode": "caller",
          "local_addr": "0.0.0.0:0",
          "remote_addr": "127.0.0.1:9200",
          "latency_ms": 200
        },
        {
          "type": "rtp",
          "id": "rtp-out-local",
          "name": "Local RTP Output",
          "dest_addr": "127.0.0.1:5005"
        }
      ]
    }
  ]
}
