{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8080
  },
  "monitor": {
    "listen_addr": "0.0.0.0",
    "listen_port": 9090
  },
  "flows": [
    {
      "id": "multi-fanout",
      "name": "SRT to Multi-Protocol Fan-out",
      "enabled": true,
      "input": {
        "type": "srt",
        "mode": "listener",
        "local_addr": "0.0.0.0:9000",
        "latency_ms": 200,
        "passphrase": "mySecurePassphrase123"
      },
      "outputs": [
        {
          "type": "rtp",
          "id": "rtp-local",
          "name": "Local RTP Multicast",
          "dest_addr": "239.1.1.1:5004",
          "dscp": 46
        },
        {
          "type": "srt",
          "id": "srt-remote",
          "name": "Remote SRT Destination",
          "mode": "caller",
          "local_addr": "0.0.0.0:0",
          "remote_addr": "10.0.1.50:9001",
          "latency_ms": 500
        },
        {
          "type": "rtmp",
          "id": "twitch-live",
          "name": "Twitch Delivery",
          "dest_url": "rtmp://live.twitch.tv/app",
          "stream_key": "live_YOUR_KEY",
          "reconnect_delay_secs": 5
        },
        {
          "type": "hls",
          "id": "youtube-hls",
          "name": "YouTube HLS",
          "ingest_url": "https://a.upload.youtube.com/http_upload_hls",
          "segment_duration_secs": 2.0,
          "max_segments": 5
        }
      ]
    }
  ]
}
