{
  "version": 1,
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8081
  },
  "monitor": {
    "listen_addr": "0.0.0.0",
    "listen_port": 9091
  },
  "flows": [
    {
      "id": "caller-flow",
      "name": "RTP In -> SRT Caller",
      "enabled": true,
      "input": {
        "type": "rtp",
        "bind_addr": "0.0.0.0:5000"
      },
      "outputs": [
        {
          "type": "srt",
          "id": "srt-out",
          "name": "SRT Caller Output",
          "mode": "caller",
          "local_addr": "0.0.0.0:0",
          "remote_addr": "127.0.0.1:9000",
          "latency_ms": 200
        }
      ]
    }
  ]
}
